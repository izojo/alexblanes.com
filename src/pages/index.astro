---
// Alex Blanes — Portfolio
// Commit 018: Interview video section + FTP content sync

// ── Data imports ─────────────────────────────
import site from "../data/site.js";
import nav from "../data/nav.js";
import hero from "../data/hero.js";
import stats from "../data/stats.js";
import { sectionLabel as intLabel, question as intQuestion, video as intVideo } from "../data/interview.js";
import { sectionLabel as capLabel, sectionTitle as capTitle, cards as capCards } from "../data/capabilities.js";
import { sectionLabel as expLabel, sectionTitle as expTitle, featured, timeline, additional } from "../data/experience.js";
import { sectionLabel as eduLabel, sectionTitle as eduTitle, entries as eduEntries } from "../data/education.js";
import { sectionLabel as platLabel, sectionTitle as platTitle, tools } from "../data/platforms.js";
import { sectionLabel as factsLabel, sectionTitle as factsTitle, cards as factCards } from "../data/funfacts.js";
import { sectionLabel as howLabel, sectionTitle as howTitle, values as howValues } from "../data/how.js";
import { sectionLabel as openLabel, sectionTitle as openTitle, intro as openIntro, cells as openCells, salaryNote } from "../data/opento.js";
import footer from "../data/footer.js";
---

<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="index, follow" />
  <title>{site.title}</title>
  <meta name="description" content={site.description} />

  <!-- OpenGraph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={site.title} />
  <meta property="og:description" content={site.ogDescription} />
  <meta property="og:image" content={site.ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content={site.url} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={site.title} />
  <meta name="twitter:description" content={site.twitterDescription} />
  <meta name="twitter:image" content={site.ogImage} />

  <!-- Self-hosted fonts: preload critical files for fastest render -->
  <link rel="preload" href="/fonts/InstrumentSerif-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/DMSans-Variable.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Canonical -->
  <link rel="canonical" href={`${site.url}/`} />

  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="icon" href="/favicon-512.png" type="image/png" sizes="512x512">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <!-- JSON-LD: Person schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${site.url}/#person`,
    "name": site.person.name,
    "givenName": site.person.givenName,
    "familyName": site.person.familyName,
    "url": site.url,
    "image": site.person.image,
    "jobTitle": site.person.jobTitle,
    "description": site.person.description,
    "email": site.person.email,
    "telephone": site.person.telephone,
    "knowsLanguage": site.person.knowsLanguage,
    "nationality": site.person.nationality.map(n => ({ "@type": "Country", "name": n.name })),
    "knowsAbout": site.person.knowsAbout,
    "sameAs": site.person.sameAs,
    "alumniOf": site.person.alumniOf.map(a => ({
      "@type": "CollegeOrUniversity",
      "name": a.name,
      "url": a.url,
    })),
    "hasOccupation": [{
      "@type": "Occupation",
      "name": site.person.hasOccupation.name,
      "occupationLocation": { "@type": "Country", "name": site.person.hasOccupation.location },
      "description": site.person.hasOccupation.description,
      "skills": site.person.hasOccupation.skills,
    }],
    "worksFor": {
      "@type": "Organization",
      "name": site.person.worksFor.name,
      "description": site.person.worksFor.description,
    },
    "seeks": {
      "@type": "Demand",
      "description": site.person.seeks,
    },
  }, null, 2)} />

  <!-- JSON-LD: WebSite schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${site.url}/#website`,
    "name": site.title,
    "url": site.url,
    "description": site.website.description,
    "author": { "@id": `${site.url}/#person` },
    "inLanguage": "en-GB",
  }, null, 2)} />

  <!-- JSON-LD: WebPage schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${site.url}/#webpage`,
    "url": `${site.url}/`,
    "name": site.title,
    "description": site.description,
    "isPartOf": { "@id": `${site.url}/#website` },
    "about": { "@id": `${site.url}/#person` },
    "inLanguage": "en-GB",
    "datePublished": site.webpage.datePublished,
    "dateModified": site.webpage.dateModified,
  }, null, 2)} />

  <!-- Wistia video player -->
  <script src="https://fast.wistia.com/player.js" async></script>
  <script src={`https://fast.wistia.com/embed/${intVideo.mediaId}.js`} async type="module"></script>
</head>

<body>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <div class="nav-inner">
      <a href="#hero" class="nav-logo">AB</a>
      <div class="nav-links">
        {nav.map(link => (
          link.cta
            ? <a href={link.href} class="nav-cta">{link.label}</a>
            : <a href={link.href}>{link.label}</a>
        ))}
      </div>
      <button class="nav-toggle" aria-label="Toggle menu" id="navToggle">
        <span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu">
    {nav.map(link => (
      <a href={link.href}>{link.label}</a>
    ))}
  </div>

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="hero-grid">
      <div class="hero-text">
        <p class="hero-label">{hero.label}</p>
        <h1 class="hero-name">{hero.firstName}<br />{hero.lastName}</h1>
        <p class="hero-tagline">{hero.tagline}</p>
        <div class="hero-actions">
          {hero.buttons.map(btn => (
            btn.external
              ? <a href={btn.href} target="_blank" rel="noopener" class={`btn btn-${btn.style}`}>{btn.label}</a>
              : <a href={btn.href} class={`btn btn-${btn.style}`}>{btn.label}</a>
          ))}
        </div>
        {hero.recruiterLink && (
          <p style="margin-top:1.5rem;font-size:0.85rem;color:#8A8A8A;">
            <a href={hero.recruiterLink.href} style="color:#8A8A8A;text-decoration:underline;text-decoration-color:#8A8A8A;text-underline-offset:3px;transition:color 0.2s;">
              {hero.recruiterLink.text}
            </a>
          </p>
        )}
      </div>
      <div class="hero-image-wrap">
        <div class="hero-image-frame">
          <picture>
            <source
              type="image/webp"
              srcset="/headshot-320w.webp 320w, /headshot-480w.webp 480w, /headshot-640w.webp 640w, /headshot-960w.webp 960w, /headshot-1000w.webp 1000w"
              sizes="(max-width: 900px) 320px, 400px"
            />
            <img src="/headshot.jpg" alt="Alex Blanes" class="hero-image" width="480" height="480" loading="eager" fetchpriority="high" />
          </picture>
        </div>
        <div class="hero-image-accent"></div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="stats-grid">
      {stats.map(s => (
        <div class="stat">
          <span class="stat-value">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- INTERVIEW VIDEO -->
  <section class="interview-section" id="interview">
    <div class="section-header">
      <p class="section-label">{intLabel}</p>
    </div>
    <blockquote class="interview-question">
      <p>{intQuestion}</p>
    </blockquote>
    <div class="interview-video">
      <wistia-player media-id={intVideo.mediaId} aspect={intVideo.aspect}></wistia-player>
    </div>
  </section>

  <!-- CORE CAPABILITIES -->
  <section class="section capabilities" id="capabilities">
    <div class="section-header">
      <p class="section-label">{capLabel}</p>
      <h2 class="section-title">{capTitle}</h2>
    </div>
    <div class="cap-grid">
      {capCards.map(card => (
        <div class="cap-card">
          <h3 class="cap-title">{card.title}</h3>
          <ul class="cap-items">
            {card.items.map(item => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section class="section experience" id="experience">
    <div class="section-header">
      <p class="section-label">{expLabel}</p>
      <h2 class="section-title">{expTitle}</h2>
    </div>

    <!-- Featured role -->
    <article class="role role-featured" style="--delay: 0s">
      <div class="role-aside">
        <span class="role-period">{featured.period}</span>
        <span class="role-location">{featured.location}</span>
      </div>
      <div class="role-main">
        <div class="role-header">
          <h3 class="role-title">{featured.title}</h3>
          <span class="role-company">{featured.company}</span>
        </div>
        <p class="role-context">{featured.context}</p>
        {featured.subsections.map(sub => (
          <div class="role-subsection">
            <h4 class="role-subheading">{sub.heading}</h4>
            <ul class="role-highlights">
              {sub.bullets.map(b => <li set:html={b} />)}
            </ul>
          </div>
        ))}
      </div>
    </article>

    <!-- Timeline roles -->
    <div class="timeline">
      {timeline.map((role, i) => (
        <article class="role" style={`--delay: ${(i + 1) * 0.05}s`}>
          <div class="role-aside">
            <span class="role-period">{role.period}</span>
            <span class="role-location">{role.location}</span>
          </div>
          <div class="role-main">
            <div class="role-header">
              <h3 class="role-title">{role.title}</h3>
              <span class="role-company">{role.company}</span>
            </div>
            <p class="role-context">{role.context}</p>
            <ul class="role-highlights">
              {role.bullets.map(b => <li set:html={b} />)}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <!-- Additional roles -->
    <div class="additional-roles">
      <h3 class="additional-roles-title">Additional Roles</h3>
      {additional.map(role => (
        <div class="additional-role">
          <div class="additional-role-header">
            <span class="additional-role-name">{role.title}</span>
            <span class="additional-role-sep">•</span>
            <span class="additional-role-company">{role.company}</span>
            <span class="additional-role-period">{role.period}</span>
          </div>
          <p class="additional-role-summary">{role.summary}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- EDUCATION -->
  <section class="section education" id="education">
    <div class="section-header">
      <p class="section-label">{eduLabel}</p>
      <h2 class="section-title">{eduTitle}</h2>
    </div>
    <div class="edu-grid">
      {eduEntries.map(edu => (
        <div class="edu-card">
          <span class="edu-year">{edu.year}</span>
          <h3 class="edu-degree">{edu.degree}</h3>
          <p class="edu-school">{edu.school}</p>
          <span class="edu-grade">{edu.grade}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- PLATFORMS & TOOLS -->
  <section class="section platforms-section" id="platforms">
    <div class="section-header">
      <p class="section-label">{platLabel}</p>
      <h2 class="section-title">{platTitle}</h2>
    </div>
    <div class="tags">
      {tools.map(tool => (
        <span class="tag tag-alt">{tool}</span>
      ))}
    </div>
  </section>

  <!-- FUN FACTS -->
  <section class="section facts-section" id="facts">
    <div class="section-header">
      <p class="section-label">{factsLabel}</p>
      <h2 class="section-title" set:html={factsTitle} />
    </div>
    <div class="facts-grid">
      {factCards.map(card => (
        <div class="fact-card">
          <span class="fact-emoji">{card.emoji}</span>
          <p set:html={card.html} />
        </div>
      ))}
    </div>
  </section>

  <!-- HOW I WORK -->
  <section class="section how-section" id="how">
    <div class="section-header">
      <p class="section-label">{howLabel}</p>
      <h2 class="section-title">{howTitle}</h2>
    </div>
    <div class="how-list">
      {howValues.map((v, i) => (
        <div class="how-item" style={`--delay: ${i * 0.05}s`}>
          <span class="how-num">{i + 1}</span>
          <div class="how-content">
            <h3 class="how-title">{v.title}</h3>
            <p class="how-desc" set:html={v.desc} />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- OPEN TO -->
  <section class="section opento" id="opento" style="scroll-margin-top: 100px;">
    <div class="section-header" style="text-align:center;">
      <p class="section-label">{openLabel}</p>
      <h2 class="section-title">{openTitle}</h2>
    </div>
    <p class="opento-intro">{openIntro}</p>
    <div class="opento-grid">
      {openCells.map((cell, i) => (
        <div class="opento-cell" style={`--delay: ${i * 0.05}s`}>
          <p class="opento-cell-label">{cell.label}</p>
          <p class="opento-cell-primary">{cell.primary}</p>
          <p class="opento-cell-qualifier">{cell.qualifier}</p>
        </div>
      ))}
    </div>
    <p class="opento-salary-note">{salaryNote}</p>
  </section>

  <footer class="footer" id="contact">
    <div class="footer-inner">
      <p class="footer-label">{footer.label}</p>
      <h2 class="footer-title">{footer.title}</h2>
      <a href={footer.emailCta.href} target="_blank" rel="noopener" class="btn btn-primary btn-lg">{footer.emailCta.label}</a>
      <a href={footer.linkedinCta.href} target="_blank" rel="noopener" class="btn btn-ghost btn-lg">{footer.linkedinCta.label}</a>
      <p class="footer-phone"><a href={footer.phone.href}>{footer.phone.display}</a></p>
      <p class="footer-copy">{footer.copyright}</p>
    </div>
  </footer>

  <script type="module">
    const r = document.getElementById("navToggle"),
      o = document.getElementById("mobileMenu");
    r?.addEventListener("click", () => {
      o?.classList.toggle("open");
      r.classList.toggle("open");
    });
    o?.querySelectorAll("a").forEach((e) => {
      e.addEventListener("click", () => {
        o?.classList.remove("open");
        r?.classList.remove("open");
      });
    });
    const c = document.getElementById("nav"),
      l = new IntersectionObserver(
        ([e]) => c?.classList.toggle("scrolled", !e.isIntersecting),
        { threshold: 0.8 }
      ),
      n = document.getElementById("hero");
    n && l.observe(n);
    const s = new IntersectionObserver(
      (e) => {
        e.forEach((t) => {
          if (t.isIntersecting) {
            t.target.classList.add("revealed");
            s.unobserve(t.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );
    document
      .querySelectorAll(
        ".role, .edu-card, .cap-card, .section-header, .stat, .additional-role, .fact-card, .how-item, .opento-cell, .interview-question, .interview-video"
      )
      .forEach((e) => s.observe(e));
    document.querySelectorAll('a[href^="http"]').forEach((e) => {
      e.setAttribute("target", "_blank");
      e.setAttribute("rel", "noopener");
    });
  </script>
</body>
</html>

<style is:global>
  /* Self-hosted @font-face declarations */
  @font-face {
    font-family: "Instrument Serif";
    src: url("/fonts/InstrumentSerif-Regular.woff2") format("woff2");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Instrument Serif";
    src: url("/fonts/InstrumentSerif-Italic.woff2") format("woff2");
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: "DM Sans";
    src: url("/fonts/DMSans-Variable.woff2") format("woff2");
    font-weight: 300 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "DM Sans";
    src: url("/fonts/DMSans-Italic-Variable.woff2") format("woff2");
    font-weight: 300 700;
    font-style: italic;
    font-display: swap;
  }

  *,
  *:before,
  *:after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --cream: #FAF7F2;
    --warm-white: #FDFCFA;
    --ink: #1A1A1A;
    --ink-light: #4A4A4A;
    --ink-muted: #8A8A8A;
    --terracotta: #C4704B;
    --terracotta-light: #E8956F;
    --terracotta-bg: #FDF0EA;
    --sand: #EDE8DF;
    --sand-dark: #D4CEC4;
    --border: #E5E0D8;
    --surface-dark: #1A1A1A;
    --on-dark: #FAF7F2;
    --on-dark-muted: #D4CEC4;
    --radius: 12px;
    --radius-lg: 20px;
    --font-display: "Instrument Serif", Georgia, serif;
    --font-body: "DM Sans", system-ui, sans-serif;
    --max-w: 1120px;
    --px: clamp(1.25rem, 4vw, 2.5rem);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --cream: #141413;
      --warm-white: #1C1C1A;
      --ink: #EDE9E3;
      --ink-light: #B8B4AC;
      --ink-muted: #7A7872;
      --terracotta: #D4845E;
      --terracotta-light: #E8A07A;
      --terracotta-bg: #2C2018;
      --sand: #2A2826;
      --sand-dark: #3A3834;
      --border: #2E2C2A;
      --surface-dark: #0E0E0D;
      --on-dark: #EDE9E3;
      --on-dark-muted: #7A7872;
    }
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink);
    background: var(--cream);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .role-main a,
  .additional-role-summary a,
  .fact-card a,
  .edu-card a,
  .cap-card a,
  .hero-tagline a,
  .section a:not(.btn) {
    color: var(--terracotta);
    text-decoration: underline;
    text-decoration-color: var(--terracotta);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
    transition: color 0.2s, text-decoration-color 0.2s;
  }

  .role-main a:hover,
  .additional-role-summary a:hover,
  .fact-card a:hover,
  .edu-card a:hover,
  .cap-card a:hover,
  .hero-tagline a:hover,
  .section a:not(.btn):hover {
    color: var(--terracotta-light);
    text-decoration-color: var(--terracotta-light);
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  ul {
    list-style: none;
  }

  /* Scroll reveal */
  .role, .edu-card, .cap-card, .section-header, .stat, .additional-role, .fact-card, .opento-cell, .interview-question, .interview-video {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: var(--delay, 0s);
  }
  .revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* NAV */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem var(--px);
    transition: background 0.3s, box-shadow 0.3s, backdrop-filter 0.3s;
  }
  .nav.scrolled {
    background: #faf7f2d9;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 1px 0 var(--border);
  }
  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-light);
  }
  .nav-links a:hover {
    color: var(--terracotta);
  }
  .nav-cta {
    background: var(--surface-dark);
    color: var(--on-dark) !important;
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-size: 0.8125rem;
    transition: background 0.2s;
  }
  .nav-cta:hover {
    background: var(--terracotta);
  }
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    width: 28px;
    height: 20px;
    position: relative;
    z-index: 110;
  }
  .nav-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--ink);
    position: absolute;
    left: 0;
    transition: all 0.3s;
  }
  .nav-toggle span:first-child { top: 4px; }
  .nav-toggle span:last-child { bottom: 4px; }
  .nav-toggle.open span:first-child { top: 50%; transform: translateY(-50%) rotate(45deg); }
  .nav-toggle.open span:last-child { bottom: 50%; transform: translateY(50%) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 99;
    background: var(--cream);
    padding: 5rem var(--px) 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    font-size: 1.25rem;
    font-weight: 500;
    transform: translateY(-100%);
    transition: transform 0.35s ease;
    box-shadow: 0 4px 24px #00000014;
  }
  .mobile-menu.open { transform: translateY(0); }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-toggle { display: block; }
  }

